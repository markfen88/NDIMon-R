[Unit]
Description=NDIMon-R Watchdog (monitors all services)
After=network-online.target
Wants=network-online.target ndimon-r.service ndimon-api.service ndimon-finder.service

[Service]
Type=notify
NotifyAccess=all
WatchdogSec=60
Restart=always
RestartSec=5
ExecStart=NDIMON_INSTALL_DIR/scripts/ndimon-watchdog.sh

[Install]
WantedBy=multi-user.target
